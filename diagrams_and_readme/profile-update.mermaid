sequenceDiagram
    actor User
    User ->> ProfileController: PATCH /api/v1/profile
    ProfileController ->> ProfileService: updateProfile(bio, avatarUrl, displayName, username)
    ProfileService -->> ProfileController: Profile
    ProfileController ->> ProfileController: resolveCurrentUserId()
    ProfileController ->> ProfileController: resolveAuthProvider(userId)
    ProfileController -->> User: 200 ApiResponse<GetProfileResponse>
