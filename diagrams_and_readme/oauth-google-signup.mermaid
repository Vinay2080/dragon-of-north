sequenceDiagram
    actor User
    User ->> OAuthController: POST /api/v1/auth/oauth/google/signup
    OAuthController ->> AuthRequestContext: fromHttpRequest(request, deviceId)
    OAuthController ->> OAuthService: signupWithGoogle(idToken, expectedIdentifier, context, response)
    OAuthService -->> OAuthController: MfaOrchestrationResult
    alt challengeRequired == true
        OAuthController -->> User: 200 ApiResponse<MfaChallengeResponse>
    else challengeRequired == false
        OAuthController -->> User: 200 ApiResponse {message: "OAuth signup successful"}
    end
